---
import { Icon } from 'astro-icon/components';
import Button from '../ui/Button.astro';
---

<section class="relative py-16 md:py-24 overflow-hidden arcade-grid-bg">
  <!-- Gradient orbs -->
  <div
    class="absolute top-1/3 left-1/4 w-125 h-125 rounded-full opacity-15 blur-[120px] pointer-events-none"
    style="background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>
  <div
    class="absolute bottom-1/4 right-1/4 w-125 h-125 rounded-full opacity-10 blur-[100px] pointer-events-none"
    style="background: radial-gradient(circle, var(--color-accent-secondary) 0%, transparent 70%);"
    aria-hidden="true"
  ></div>

  <div class="relative max-w-6xl mx-auto px-6">
    <div class="max-w-3xl">
      <!-- Availability badge -->
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-accent/20 bg-accent/5 mb-8 fade-up">
        <span class="w-2 h-2 rounded-full bg-success text-success arcade-pulse"></span>
        <Icon name="ph:broadcast-duotone" class="w-3.5 h-3.5 text-accent" />
        <span class="text-xs font-mono font-medium text-accent">DISPONIBLE PARA PROYECTOS</span>
      </div>

      <!-- Name -->
      <h1
        class="text-5xl md:text-7xl font-extrabold tracking-tighter leading-[1.1] mb-6 fade-up"
        style="animation-delay: 100ms"
        transition:name="hero-title"
      >
        <span class="gradient-text-animated">Victor_</span>
      </h1>

      <!-- Role -->
      <p
        class="text-xl md:text-2xl font-semibold text-text-muted tracking-tight mb-4 fade-up"
        style="animation-delay: 200ms"
      >
        Full-Stack Developer <span class="text-accent">&amp;</span> Software Architect
      </p>

      <!-- Tagline -->
      <p
        class="text-sm text-text-muted/80 max-w-xl mb-10 fade-up font-mono"
        style="animation-delay: 300ms"
      >
        <span class="text-accent">&gt;</span> Diseño y construyo soluciones escalables — desde la arquitectura hasta producción.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 fade-up" style="animation-delay: 400ms">
        <Button href="/projects" variant="primary" size="lg">
          Ver Proyectos
          <Icon name="ph:arrow-right-duotone" class="w-5 h-5" />
        </Button>
        <Button href="/contact" variant="secondary" size="lg">
          <Icon name="ph:envelope-duotone" class="w-5 h-5" />
          Contactar
        </Button>
      </div>
    </div>
  </div>
</section>
