---
import { Icon } from 'astro-icon/components';
import Button from '../ui/Button.astro';
import { siteConfig } from '../../data/site';
---

<section class="py-14 fade-up">
  <div class="max-w-6xl mx-auto px-6">
    <div class="rounded-2xl arcade-card p-10 md:p-16 text-center relative overflow-hidden">
      <!-- Gradient orbs -->
      <div
        class="absolute top-0 left-1/3 w-[300px] h-[200px] rounded-full opacity-15 blur-[80px] pointer-events-none"
        style="background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"
        aria-hidden="true"
      ></div>
      <div
        class="absolute bottom-0 right-1/3 w-[250px] h-[150px] rounded-full opacity-10 blur-[60px] pointer-events-none"
        style="background: radial-gradient(circle, var(--color-accent-secondary) 0%, transparent 70%);"
        aria-hidden="true"
      ></div>

      <div class="relative">
        <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-4">
          ¿Tienes un proyecto en mente<span class="gradient-text">?</span>
        </h2>
        <p class="text-text-muted text-lg mb-8 max-w-lg mx-auto">
          Si buscas un desarrollador que lleve tu idea desde la arquitectura hasta producción, hablemos.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <Button href="/contact" variant="primary" size="lg">
            <Icon name="ph:envelope-duotone" class="w-5 h-5" />
            Contactar
          </Button>
          <Button href={siteConfig.links.linkedin} variant="secondary" size="lg">
            <Icon name="ph:linkedin-logo-duotone" class="w-5 h-5" />
            LinkedIn
          </Button>
        </div>
      </div>
    </div>
  </div>
</section>
