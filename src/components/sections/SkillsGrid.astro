---
import { Icon } from 'astro-icon/components';
import SectionHeading from '../ui/SectionHeading.astro';
import { skillCategories } from '../../data/skills';
---

<section class="py-14 fade-up">
  <div class="max-w-6xl mx-auto px-6">
    <SectionHeading
      title="Stack Tecnológico"
      subtitle="Herramientas y tecnologías que uso en producción"
    />

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {skillCategories.map((category, catIdx) => (
        <div
          class="rounded-xl arcade-card p-6 fade-up"
          style={`animation-delay: ${catIdx * 80}ms`}
        >
          <h3 class="text-sm font-semibold uppercase tracking-widest text-accent font-mono mb-4">
            <span class="text-accent-secondary">//</span> {category.title}
          </h3>
          <div class="space-y-3">
            {category.skills.map((skill) => (
              <div class="flex items-center gap-3 text-text-muted hover:text-accent transition-all duration-300 group/skill">
                <Icon name={skill.icon} class="w-6 h-6 shrink-0 group-hover/skill:drop-shadow-[0_0_6px_var(--color-glow)]" />
                <span class="text-sm font-medium">{skill.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
