---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-12">
  <h2 class="text-3xl md:text-4xl font-extrabold tracking-tight">
    {title}<span class="gradient-text">.</span>
  </h2>
  {subtitle && (
    <p class="mt-3 text-text-muted text-lg max-w-2xl">{subtitle}</p>
  )}
  <div class="mt-4 h-px w-24 bg-gradient-to-r from-accent via-accent-secondary to-transparent"></div>
</div>
