---
import { Icon } from 'astro-icon/components';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Button from '../components/ui/Button.astro';
import { siteConfig } from '../data/site';
---

<BaseLayout
  title="Contacto — Victor"
  description="¿Tienes un proyecto en mente? Hablemos sobre cómo puedo ayudarte."
>
  <section class="py-14 arcade-grid-bg relative">
    <!-- Glow orb -->
    <div
      class="absolute top-1/3 left-1/4 w-[400px] h-[400px] rounded-full opacity-10 blur-[100px] pointer-events-none"
      style="background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);"
      aria-hidden="true"
    ></div>

    <div class="relative max-w-6xl mx-auto px-6">
      <SectionHeading
        title="Contacto"
        subtitle="¿Tienes un proyecto en mente? Hablemos."
      />

      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-4xl">
        <!-- Form -->
        <form id="contact-form" class="space-y-6 fade-up">
          <div>
            <label for="name" class="block text-sm font-medium font-mono mb-2 text-accent">name_</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full px-4 py-3 rounded-lg bg-bg-subtle border border-border/50 text-text placeholder:text-text-muted/40 focus:outline-none focus:border-accent focus:glow-cyan transition-all duration-300"
              placeholder="Tu nombre"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium font-mono mb-2 text-accent">email_</label>
            <input
              type="email"
              id="email"
              name="email"
              required
              class="w-full px-4 py-3 rounded-lg bg-bg-subtle border border-border/50 text-text placeholder:text-text-muted/40 focus:outline-none focus:border-accent focus:glow-cyan transition-all duration-300"
              placeholder="tu@email.com"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium font-mono mb-2 text-accent">message_</label>
            <textarea
              id="message"
              name="message"
              rows="5"
              required
              class="w-full px-4 py-3 rounded-lg bg-bg-subtle border border-border/50 text-text placeholder:text-text-muted/40 focus:outline-none focus:border-accent focus:glow-cyan transition-all duration-300 resize-none"
              placeholder="Cuéntame sobre tu proyecto..."
            ></textarea>
          </div>

          <Button variant="primary" size="lg" type="submit">
            <Icon name="ph:paper-plane-tilt-duotone" class="w-5 h-5" />
            Enviar mensaje
          </Button>
        </form>

        <!-- Info -->
        <div class="fade-up" style="animation-delay: 200ms">
          <div class="rounded-xl arcade-card p-8 space-y-6">
            <div>
              <h3 class="font-bold mb-2 font-mono text-sm text-accent flex items-center gap-2">
                <Icon name="ph:envelope-duotone" class="w-5 h-5" />
                // Email directo
              </h3>
              <a href={siteConfig.links.email} class="text-text-muted hover:text-accent text-sm transition-colors">
                victorveliz98.vv@gmail.com
              </a>
            </div>
            <div>
              <h3 class="font-bold mb-2 font-mono text-sm text-accent-secondary flex items-center gap-2">
                <Icon name="ph:linkedin-logo-duotone" class="w-5 h-5" />
                // LinkedIn
              </h3>
              <a href={siteConfig.links.linkedin} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent-secondary text-sm transition-colors">
                /in/victor-veliz
              </a>
            </div>
            <div>
              <h3 class="font-bold mb-2 font-mono text-sm text-accent-tertiary flex items-center gap-2">
                <Icon name="ph:github-logo-duotone" class="w-5 h-5" />
                // GitHub
              </h3>
              <a href={siteConfig.links.github} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent-tertiary text-sm transition-colors">
                @chillcoffeeing
              </a>
            </div>

            <div class="pt-4 border-t border-border/50">
              <div class="flex items-center gap-2">
                <Icon name="ph:broadcast-duotone" class="w-5 h-5 text-success" />
                <span class="w-2 h-2 rounded-full bg-success text-success arcade-pulse"></span>
                <span class="text-sm text-text-muted font-mono">status: disponible</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
